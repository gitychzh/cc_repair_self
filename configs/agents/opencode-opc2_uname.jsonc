{
  "$schema": "https://opencode.ai/config.json",
  "_comment": "OpenCode (opc2_uname) 配置 — 通过 passthrough proxy gateway (40003) 路由",
  "_key_changes": "R29: 1) baseURL 从 40001→40003; 2) model 从 glm5.2_oc→dsv4p_oc; 3) fallback 去掉",
  "model": "proxy-gateway/dsv4p_oc",
  "small_model": "proxy-gateway/dsv4p_oc",
  "provider": {
    "proxy-gateway": {
      "id": "proxy-gateway",
      "name": "Proxy Gateway 40003 (OpenCode → dsv4p)",
      "npm": "@ai-sdk/openai-compatible",
      "api": "http://127.0.0.1:40003/v1",
      "options": {
        "apiKey": "sk-litellm-local",
        "baseURL": "http://127.0.0.1:40003/v1"
      },
      "models": {
        "dsv4p_oc": {
          "id": "dsv4p_oc",
          "name": "DSv4P (OpenCode)",
          "family": "deepseek",
          "tool_call": true,
          "reasoning": true,
          "temperature": true,
          "limit": {
            "context": 170000,
            "output": 65536
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        }
      }
    }
  }
}
