{
  "_comment": "OpenClaw (opc2_uname) 配置模板 — 通过 passthrough proxy gateway (40003) 路由",
  "_key_changes": "R29: 1) baseUrl 从 40001→40003; 2) model 从 glm5.2_ol→dsv4p_ol; 3) fallback 去掉",
  "gateway": {
    "mode": "local",
    "auth": {
      "token": "opclaw123"
    },
    "bind": "lan",
    "port": 18789
  },
  "models": {
    "providers": {
      "proxy-gateway": {
        "baseUrl": "http://127.0.0.1:40003/v1",
        "apiKey": "sk-litellm-local",
        "api": "openai-completions",
        "models": [
          {
            "id": "dsv4p_ol",
            "name": "DSv4P (OpenClaw)",
            "contextWindow": 170000
          }
        ]
      }
    },
    "mode": "replace"
  },
  "agents": {
    "defaults": {
      "verboseDefault": "on",
      "model": {
        "primary": "proxy-gateway/dsv4p_ol"
      },
      "models": {
        "proxy-gateway/dsv4p_ol": {
          "alias": "DSv4P (OpenClaw)"
        }
      }
    }
  }
}
