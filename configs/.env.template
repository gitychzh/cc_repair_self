# Copy this file to .env on each machine.
# POSTGRES_PASSWORD can differ per machine — it's a local secret.
# opc_uname uses: litellm_pg_2026
# opc2_uname uses: litellm_pg_pass
# R29: PostgreSQL hosts one DB: litellm_glm51 (for ms_uni41001, 140 dep)
# R33: Added litellm_nv (for 5 NV LiteLLM containers, 10 dep)
POSTGRES_PASSWORD=litellm_pg_pass

# ── Proxy timeouts (R27) ──
# PROXY_TIMEOUT: Overall request timeout concept (seconds, for docs)
# UPSTREAM_TIMEOUT: Per-key HTTPConnection timeout (seconds, how long to wait per individual key attempt)
PROXY_TIMEOUT=300
UPSTREAM_TIMEOUT=60

