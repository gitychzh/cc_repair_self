# Copy this file to .env on each machine.
# POSTGRES_PASSWORD can differ per machine — it's a local secret.
# opc_uname uses: litellm_pg_2026
# opc2_uname uses: litellm_pg_pass
# R26: PostgreSQL now hosts two DBs: litellm_glm51 (for ms_uni41001) and litellm_glm51_fallback (for ms_uni41002)
POSTGRES_PASSWORD=litellm_pg_pass

# ── Proxy timeouts (R27) ──
# PROXY_TIMEOUT: Overall request timeout concept (seconds, for docs)
# UPSTREAM_TIMEOUT: Per-key HTTPConnection timeout (seconds, how long to wait per individual key attempt)
PROXY_TIMEOUT=300
UPSTREAM_TIMEOUT=60

# ── npm global prefix (CRITICAL for CC auto-update) ──
# Without ~/.npmrc, npm defaults prefix to /usr (root-owned) → CC auto-update fails with "nowrite permission"
# Each machine MUST have ~/.npmrc setting prefix to user-owned directory:
#   opc_uname:  prefix=/home/opc_uname/.npm-global
#   opc2_uname: prefix=/home/opc2_uname/.npm-global
# Example ~/.npmrc content:
#   prefix=/home/opc_uname/.npm-global
#   registry=https://registry.npmjs.org/
