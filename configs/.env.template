# ── npm global prefix (CRITICAL for CC auto-update) ──
# Without ~/.npmrc, npm defaults prefix to /usr (root-owned) → CC auto-update fails with "nowrite permission"
# Each machine MUST have ~/.npmrc setting prefix to user-owned directory:
#   opc_uname:  prefix=/home/opc_uname/.npm-global
#   opc2_uname: prefix=/home/opc2_uname/.npm-global
# Example ~/.npmrc content:
#   prefix=/home/opc_uname/.npm-global
#   registry=https://registry.npmjs.org/

# ── R40: Hermes hm40006 DB logging (per-machine identity) ──
# HM_HOST_MACHINE identifies which machine produced the log row (for cross-machine dashboards).
#   opc_uname  → HM_HOST_MACHINE=opc_uname
#   opc2_uname → HM_HOST_MACHINE=opc2_uname
HM_HOST_MACHINE=opc_uname
