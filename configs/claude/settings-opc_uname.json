{
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:40001",
    "ANTHROPIC_API_KEY": "sk-litellm-local",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "8192",
    "API_TIMEOUT_MS": "300000",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "180000"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task",
      "TodoWrite",
      "NotebookEdit",
      "Agent",
      "AskUserQuestion",
      "EnterPlanMode",
      "ExitPlanMode",
      "ScheduleWakeup",
      "CronCreate",
      "CronDelete",
      "CronList",
      "Skill",
      "TaskCreate",
      "TaskUpdate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "MemoryWrite",
      "MemoryRead",
      "MemoryDelete",
      "MemorySearch",
      "EnterWorktree",
      "ExitWorktree"
    ],
    "deny": []
  },
  "model": "glm5.1",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "defaultMode": "bypassPermissions",
  "contextWindow": 190000,
  "autoCompactWindow": 180000,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  }
}