# auto-loop — 通用配置变量模板
# 复制此文件为 config.env，填入你的项目值，然后 source 它
# 用法: source "$(dirname "$0")/config.env"

# ============================================================
# Section 1: 项目身份
# ============================================================

# 项目根目录（CC 工作目录，也是 Git 仓库）
PROJECT_DIR="${HOME}/your-project-dir"

# 项目名称（用于 screen session、日志等标识）
PROJECT_NAME="your-project"

# CC session 存储目录（由 Claude Code 自动管理）
# 格式: ~/.claude/projects/-<escaped-project-path>/
# 你需要先启动一次 CC，然后 ls ~/.claude/projects/ 找到对应目录
CC_SESSION_DIR="${HOME}/.claude/projects/-home-your-user-your-project-dir"

# ============================================================
# Section 2: Watchdog
# ============================================================

# watchdog 项目根目录（与 CC 项目分开，避免互相干扰）
WATCHDOG_DIR="${HOME}/your-watchdog-dir"

# 卡死判定阈值（秒）—— session jsonl 无新写入超过此时间判定为卡死
STALL_THRESHOLD_SEC="${STALL_THRESHOLD_SEC:-600}"

# 唤醒注入后等待响应的时间（秒）
WAKE_RETRY_SECONDS="${WAKE_RETRY_SECONDS:-90}"

# 唤醒防抖冷却时间（秒）—— 两次唤醒之间至少间隔此时间
WAKE_COOLDOWN_SEC="${WAKE_COOLDOWN_SEC:-300}"

# watchdog 执行频率（crontab 格式）
WATCHDOG_CRON="${WATCHDOG_CRON:-*/15}"

# 凌晨静默窗口（不注入，只观察）—— 小时范围，适用于 API 配额重置时段
QUIET_HOUR_START="${QUIET_HOUR_START:-2}"
QUIET_HOUR_END="${QUIET_HOUR_END:-4}"

# screen session 名称
SCREEN_NAME="${SCREEN_NAME:-claude}"

# ============================================================
# Section 3: CC 启动参数
# ============================================================

# CC 二进制路径
CLAUDE_BIN="${HOME}/.npm-global/bin/claude"

# CC 权限模式
CC_PERMISSION_MODE="bypassPermissions"

# CC 使用的模型（通过 proxy 转换后的 frontend model name）
CC_MODEL="your-model-name"

# CC 启动时是否 --resume 上次 session（watchdog 重启时使用）
# 不影响首次启动
CC_RESUME_ENABLED=true

# ============================================================
# Section 4: 基础设施（需要你按实际填写）
# ============================================================

# 配置文件部署目录（脚本会将 Git 仓库中的配置复制到此目录）
DEPLOY_DIR="/opt/your-infra-dir"

# 哪些配置文件需要从 Git repo 同步到 deploy dir
# 格式: "repo相对路径:deploy相对路径"
SYNC_MAP=(
    "configs/docker-compose.yml:docker-compose.yml"
    "configs/your-backend/config.yaml:your-backend/config.yaml"
)

# 需要监控的基础设施端点
# 格式: "名称:url"
# 注意: LiteLLM 必须用 /health/liveliness，禁用 /health（会触发 fd 耗尽）
HEALTH_ENDPOINTS=(
    "proxy:http://127.0.0.1:40001/health"
    "backend1:http://127.0.0.1:41001/health/liveliness"
    "backend2:http://127.0.0.1:42001/health/liveliness"
)

# 健康检查需要的 Authorization header（如果端点需要认证）
HEALTH_AUTH_HEADER="Authorization: Bearer sk-litellm-local"

# 需要监控的 Docker 容器名列表
EXPECTED_CONTAINERS=(
    "your_container_1"
    "your_container_2"
)

# Docker compose 文件路径
COMPOSE_FILE="${DEPLOY_DIR}/docker-compose.yml"

# 测试请求（验证端到端链路）
# 格式: "名称:url:model:格式"
TEST_REQUESTS=(
    "glm5.1:http://127.0.0.1:40001/v1/messages:glm5.1:anthropic"
    "dsv4p:http://127.0.0.1:40001/v1/messages:dsv4p:anthropic"
)

# ============================================================
# Section 5: 不可变约束（hard lint）
# ============================================================

# 你的项目有哪些不可变约束？watchdog 的 fix_infra.sh 会做 lint 检查
# 格式: "检查类型:检查内容"
# 留空 = 不做 lint
IMMUTABLE_CONSTRAINTS=()

# 示例（本项目实际值）:
# IMMUTABLE_CONSTRAINTS=(
#     "variant_ids:deepseek-ai/deepseek-v4-pro deepseek-ai/Deepseek-V4-Pro ..."
#     "rpm_value:1"
#     "frontend_model:glm5.1 dsv4p"
#     "container_names:glm5.1_uni41001 dsv4p_uni42001 ..."
#     "ports:41001 42001"
# )

# ============================================================
# Section 6: CC CronCreate 定时任务
# ============================================================

# CronCreate 间隔（分钟）
CC_CRON_INTERVAL="${CC_CRON_INTERVAL:-10}"

# CronCreate prompt 内容（CC 自动执行的逻辑）
# 修改此字符串来定义你的 CC 每轮自动做什么
CC_CRON_PROMPT="检查远程仓库是否有更新：git pull。如果有更新，分析变更并优化本地配置���所有修改必须有日志数据支撑。优化后更新部署状态文档并 push。如果没有更新，分析日志数据，有数据支撑才修改参数。"